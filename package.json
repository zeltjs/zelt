{
  "name": "zeltjs",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.x"
  },
  "scripts": {
    "build": "nx run-many -t build",
    "format": "biome format --write .",
    "format:check": "biome check .",
    "lint": "eslint . && oxlint .",
    "lint:fix": "eslint . --fix && oxlint . --fix",
    "knip": "knip",
    "test": "vitest run",
    "typecheck": "tsc -b",
    "precommit": "pnpm format:check && pnpm typecheck && pnpm lint && pnpm build && pnpm test && npx precommit-verify save",
    "prepare": "npx lefthook install"
  },
  "devDependencies": {
    "@9wick/eslint-plugin-strict-type-rules": "1.0.2",
    "@biomejs/biome": "2.4.14",
    "@eslint-community/eslint-plugin-eslint-comments": "4.7.1",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "10.3.0",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-oxlint": "1.62.0",
    "eslint-plugin-sonarjs": "4.0.3",
    "knip": "6.10.0",
    "lefthook": "2.1.6",
    "nx": "21.6.10",
    "oxlint": "1.62.0",
    "precommit-verify": "0.1.7",
    "tsdown": "0.21.10",
    "typescript": "6.0.2",
    "typescript-eslint": "8.59.1",
    "vitest": "4.1.5"
  }
}
