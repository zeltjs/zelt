    "@zeltjs/core": "workspace:*",
    "@zeltjs/openapi": "workspace:*",
    "hono": "4.12.16"
  },
  "peerDependenciesMeta": {
    "@zeltjs/openapi": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "22.19.17",
    "@zeltjs/core": "workspace:*",
    "@zeltjs/openapi": "workspace:*",
    "hono": "4.12.16"
  },
  "volta": {
    "extends": "../../package.json"
  }
