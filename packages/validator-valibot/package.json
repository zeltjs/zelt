{
  "name": "@zeltjs/validator-valibot",
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zeltjs/zelt.git",
    "directory": "packages/validator-valibot"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./openapi": {
      "import": {
        "types": "./dist/openapi/index.d.ts",
        "default": "./dist/openapi/index.js"
      },
      "require": {
        "types": "./dist/openapi/index.d.cts",
        "default": "./dist/openapi/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "typecheck": "tsc -b"
  },
  "peerDependencies": {
    "@zeltjs/openapi": "workspace:*",
    "valibot": "catalog:peer",
    "@valibot/to-json-schema": "catalog:peer"
  },
  "peerDependenciesMeta": {
    "@zeltjs/openapi": {
      "optional": true
    },
    "@valibot/to-json-schema": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@valibot/to-json-schema": "catalog:",
    "@zeltjs/core": "workspace:*",
    "@zeltjs/openapi": "workspace:*",
    "valibot": "catalog:"
  },
  "volta": {
    "extends": "../../package.json"
  },
  "main": "./dist/index.cjs"
}
