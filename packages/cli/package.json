{
  "name": "@zeltjs/cli",
  "version": "0.0.0",
  "description": "CLI for Zelt framework",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zeltjs/zelt.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "zelt": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@zeltjs/adapter-node": "workspace:*",
    "@zeltjs/core": "workspace:*",
    "chokidar": "5.0.0",
    "jiti": "2.6.1"
  },
  "peerDependencies": {
    "typescript": "catalog:peer"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "c12": "3.0.4",
    "citty": "0.1.6",
    "consola": "3.4.2",
    "ts-pattern": "5.7.1",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "valibot": "catalog:"
  },
  "volta": {
    "extends": "../../package.json"
  }
}
