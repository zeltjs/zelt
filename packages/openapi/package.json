{
  "name": "@zeltjs/openapi",
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zeltjs/zelt.git",
    "directory": "packages/openapi"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "typecheck": "tsc -b"
  },
  "peerDependencies": {
    "@zeltjs/cli": "workspace:*",
    "@zeltjs/core": "workspace:*"
  },
  "dependencies": {
    "@zeltjs/decorator-metadata": "workspace:*",
    "ts-pattern": "5.7.1"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@zeltjs/cli": "workspace:*"
  },
  "volta": {
    "extends": "../../package.json"
  },
  "main": "./dist/index.cjs"
}
