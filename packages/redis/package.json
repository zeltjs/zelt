{
  "name": "@zeltjs/redis",
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zeltjs/zelt.git",
    "directory": "packages/redis"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./testing": {
      "import": {
        "types": "./dist/testing/index.d.ts",
        "default": "./dist/testing/index.js"
      },
      "require": {
        "types": "./dist/testing/index.d.cts",
        "default": "./dist/testing/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "typecheck": "tsc -b"
  },
  "peerDependencies": {
    "@zeltjs/core": "workspace:*",
    "@zeltjs/testing": "workspace:*",
    "testcontainers": ">=10 <12"
  },
  "peerDependenciesMeta": {
    "@zeltjs/testing": {
      "optional": true
    },
    "testcontainers": {
      "optional": true
    }
  },
  "dependencies": {
    "ioredis": "5.10.1"
  },
  "devDependencies": {
    "@zeltjs/core": "workspace:*",
    "@zeltjs/testing": "workspace:*",
    "@types/node": "catalog:",
    "testcontainers": "10.25.0"
  },
  "volta": {
    "extends": "../../package.json"
  },
  "main": "./dist/index.cjs"
}
