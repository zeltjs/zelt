{
  "name": "@zeltjs/adapter-lambda",
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zeltjs/zelt.git",
    "directory": "packages/adapter-lambda"
  },
  "publishConfig": {
    "access": "public"
  },
