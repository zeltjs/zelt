{
  "name": "@zeltjs/kv",
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zeltjs/zelt.git",
    "directory": "packages/kv"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./adaptor-memory": {
      "import": {
        "types": "./dist/adaptor-memory/index.d.ts",
        "default": "./dist/adaptor-memory/index.js"
      },
      "require": {
        "types": "./dist/adaptor-memory/index.d.cts",
        "default": "./dist/adaptor-memory/index.cjs"
      }
    },
    "./adaptor-redis": {
      "import": {
        "types": "./dist/adaptor-redis/index.d.ts",
        "default": "./dist/adaptor-redis/index.js"
      },
      "require": {
        "types": "./dist/adaptor-redis/index.d.cts",
        "default": "./dist/adaptor-redis/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "typecheck": "tsc -b"
  },
  "peerDependencies": {
    "@zeltjs/core": "workspace:*",
    "@zeltjs/redis": "workspace:*",
    "vitest": ">=4 <5"
  },
  "peerDependenciesMeta": {
    "@zeltjs/redis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@zeltjs/core": "workspace:*",
    "@zeltjs/redis": "workspace:*",
    "@zeltjs/unsafe-type-lib": "workspace:*",
    "@types/node": "catalog:",
    "ioredis": "5.10.1"
  },
  "volta": {
    "extends": "../../package.json"
  },
  "main": "./dist/index.cjs"
}
