{
  "name": "@zeltjs/core",
  "version": "0.5.0",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zeltjs/zelt.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./internal-bridge/testing": {
      "types": "./dist/internal-bridge/testing.d.ts",
      "import": "./dist/internal-bridge/testing.js"
    },
    "./internal-bridge/errors": {
      "types": "./dist/internal-bridge/errors.d.ts",
      "import": "./dist/internal-bridge/errors.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@zeltjs/decorator-metadata": "workspace:*",
    "hono": "4.12.16"
  },
  "devDependencies": {
    "@needle-di/core": "1.1.2",
    "@types/node": "22.19.17",
    "croner": "9.1.0",
    "neverthrow": "8.2.0",
    "ts-pattern": "5.6.2"
  },
  "volta": {
    "extends": "../../package.json"
  }
}
