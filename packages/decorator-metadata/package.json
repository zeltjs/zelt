{
  "name": "@zeltjs/decorator-metadata",
  "version": "0.0.0",
  "description": "Runtime decorator metadata capture and TypeScript type extraction",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zeltjs/zelt.git",
    "directory": "packages/decorator-metadata"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./inspect": {
      "import": {
        "types": "./dist/inspect/index.d.ts",
        "default": "./dist/inspect/index.js"
      },
      "require": {
        "types": "./dist/inspect/index.d.cts",
        "default": "./dist/inspect/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "typecheck": "tsc -b"
  },
  "peerDependencies": {
    "typescript": "catalog:peer"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "typescript-6": "npm:typescript@~6.0.0"
  },
  "dependencies": {
    "import-meta-resolve": "4.2.0",
    "ts-pattern": "5.6.2"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@zeltjs/unsafe-type-lib": "workspace:*",
    "neverthrow": "8.2.0",
    "typescript": "catalog:"
  },
  "volta": {
    "extends": "../../package.json"
  },
  "main": "./dist/index.cjs"
}
