{
  "name": "@zeltjs/graphql",
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zeltjs/zelt.git",
    "directory": "packages/graphql"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "typecheck": "tsc -b"
  },
  "peerDependencies": {
    "@zeltjs/cli": "workspace:*",
    "@zeltjs/core": "workspace:*"
  },
  "dependencies": {
    "@standard-schema/spec": "1.1.0",
    "@zeltjs/decorator-metadata": "workspace:*",
    "graphql": "16.14.2",
    "ts-pattern": "5.6.2"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@valibot/to-json-schema": "catalog:",
    "@zeltjs/cli": "workspace:*",
    "valibot": "catalog:",
    "vitest": "catalog:"
  },
  "volta": {
    "extends": "../../package.json"
  },
  "main": "./dist/index.cjs"
}
